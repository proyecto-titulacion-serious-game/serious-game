# Nombre del proyecto
PROJECT_NAME           = "Serious Game - Electrónica VR"
PROJECT_NUMBER         = "1.0.0"

# Rutas de entrada (Solo tus scripts para que sea rápido)
INPUT                  = ./Assets/Scripts README.md
RECURSIVE              = YES
FILE_PATTERNS          = *.cs *.md

# Salida
OUTPUT_DIRECTORY       = ./docs
GENERATE_HTML          = YES
GENERATE_LATEX         = NO

# Configuración de extracción (Para que lea los XML)
