# Diagramas (Aquí usamos Graphviz)
HAVE_DOT               = YES
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
DIRECTORY_GRAPH        = YES
UML_LOOK               = YES
TEMPLATE_RELATIONS     = YES
DOT_PATH               = /usr/bin/dot

# Optimización para C#
OPTIMIZE_OUTPUT_JAVA   = YES
